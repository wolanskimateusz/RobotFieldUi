<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:RobotFieldUi.ViewModels"
        xmlns:controls="clr-namespace:RobotFieldUi.Views.Controls"
        x:DataType="vm:MainWindowViewModel"
        x:Class="RobotFieldUi.Views.MainWindow"
        Width="1200" Height="800"
        Title="RobotFieldUi">

    <Grid RowDefinitions="28,28,48,*,24">

        <!-- Row 0: TitleBar -->
        <Border Grid.Row="0" Background="{StaticResource SurfacePrimaryBrush}">
            <TextBlock Text="Robot Field UI"
                       Foreground="White"
                       VerticalAlignment="Center" Margin="8,0"/>
        </Border>

        <!-- Row 1: Menu -->
        <Border Grid.Row="1" Background="{StaticResource SurfaceSecondaryBrush}">
            <controls:MenuBarControl DataContext="{Binding MenuBar}"/>
        </Border>

        <!-- Row 2: Toolbar (placeholder) -->
        <Border Grid.Row="2" Background="{StaticResource SurfaceTertiaryBrush}">
            <TextBlock Text="[ WSTĄŻKA ]"
                       Foreground="#94A3B8"
                       VerticalAlignment="Center" Margin="8,0"/>
        </Border>

        <!-- Row 3: Główny obszar -->
        <Grid Grid.Row="3" ColumnDefinitions="200,*,48">

            <!-- Drzewko -->
            <Border Grid.Column="0" Background="{StaticResource SurfaceSecondaryBrush}">
                <TextBlock Text="[ DRZEWKO ]"
                           Foreground="#94A3B8"
                           Margin="8"/>
            </Border>

            <!-- Canvas -->
            <Border Grid.Column="1" Background="{StaticResource SurfaceCanvasBrush}">
                <TextBlock Text="[ OBSZAR EDYCJI ]"
                           Foreground="#94A3B8"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"/>
            </Border>

            <!-- Narzędzia -->
            <Border Grid.Column="2" Background="{StaticResource SurfaceSecondaryBrush}">
                <TextBlock Text="N"
                           Foreground="#94A3B8"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"/>
            </Border>

        </Grid>

        <!-- Row 4: Stopka – dane z VM przez skompilowany binding -->
        <Border Grid.Row="4" Background="{StaticResource SurfacePrimaryBrush}">
            <controls:StatusBarControl DataContext="{Binding StatusBar}"/>
        </Border>

    </Grid>
</Window>
