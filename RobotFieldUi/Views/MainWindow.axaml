<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:RobotFieldUi.ViewModels"
        xmlns:controls="using:RobotFieldUi.Views.Controls"
        x:DataType="vm:MainWindowViewModel"
        x:Class="RobotFieldUi.Views.MainWindow"
        Width="1200" Height="800"
        Title="RobotFieldUi">

    <Window.KeyBindings>
        <KeyBinding Gesture="Ctrl+Z" Command="{Binding MenuBar.UndoCommand}"/>
        <KeyBinding Gesture="Ctrl+Y" Command="{Binding MenuBar.RedoCommand}"/>
        <KeyBinding Gesture="S" Command="{Binding Ribbon.SetToolCommand}" CommandParameter="{x:Static vm:ActiveTool.Select}"/>
        <KeyBinding Gesture="H" Command="{Binding Ribbon.SetToolCommand}" CommandParameter="{x:Static vm:ActiveTool.Pan}"/>
        <KeyBinding Gesture="P" Command="{Binding Ribbon.SetToolCommand}" CommandParameter="{x:Static vm:ActiveTool.AddPoint}"/>
        <KeyBinding Gesture="M" Command="{Binding Ribbon.SetToolCommand}" CommandParameter="{x:Static vm:ActiveTool.Move}"/>
        <KeyBinding Gesture="Delete" Command="{Binding Canvas.DeleteSelectedPointsCommand}"/>
    </Window.KeyBindings>

    <Grid RowDefinitions="28,48,*,24">
        

        <!-- Row 0: Menu -->
        <Border Grid.Row="0" Background="{StaticResource SurfaceSecondaryBrush}">
            <controls:MenuBarControl DataContext="{Binding MenuBar}"/>
        </Border>

        <!-- Row 1: Wstążka -->
        <Border Grid.Row="1" Background="{StaticResource SurfaceTertiaryBrush}">
            <controls:RibbonControl DataContext="{Binding Ribbon}"/>
        </Border>

        <!-- Row 2: Główny obszar -->
        <Grid Grid.Row="2" ColumnDefinitions="200,4,*,4,200">

            <!-- Drzewko -->
            <Border Grid.Column="0" Background="{StaticResource SurfaceSecondaryBrush}">
                <controls:TreePanelControl DataContext="{Binding TreePanel}"/>
            </Border>
            
            <GridSplitter Grid.Column="1" 
                          ResizeDirection="Columns" 
                          Background="{StaticResource SurfaceTertiaryBrush}"></GridSplitter>

            <!-- Canvas -->
            <Border Grid.Column="2" Background="{StaticResource SurfaceCanvasBrush}">
                <controls:CanvasControl  DataContext="{Binding Canvas}"/>
            </Border>
            
            <GridSplitter Grid.Column="3" 
                          ResizeDirection="Columns" 
                          Background="{StaticResource SurfaceTertiaryBrush}"></GridSplitter>

            <!-- Właściwości -->
            <Border Grid.Column="4" Background="{StaticResource SurfaceSecondaryBrush}">
                <controls:PropertiesControl DataContext="{Binding Properties}"/>
            </Border>

        </Grid>

        <!-- Row 3: Stopka – dane z VM przez skompilowany binding -->
        <Border Grid.Row="3" Background="{StaticResource SurfacePrimaryBrush}">
            <controls:StatusBarControl DataContext="{Binding StatusBar}"/>
        </Border>

    </Grid>
</Window>
