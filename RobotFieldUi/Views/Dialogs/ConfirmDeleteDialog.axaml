<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="RobotFieldUi.Views.Dialogs.ConfirmDeleteDialog"
        Title="Potwierdź usunięcie"
        Width="320" Height="140"
        CanResize="False"
        WindowStartupLocation="CenterOwner">

    <StackPanel Margin="16" Spacing="14">

        <TextBlock Name="MessageText"
                   TextWrapping="Wrap"
                   FontSize="14"/>

        <StackPanel Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Spacing="8">
            <Button Name="YesButton"
                    Content="Tak"
                    Width="80"
                    IsDefault="True"
                    Click="OnYes"/>
            <Button Content="Nie"
                    Width="80"
                    IsCancel="True"
                    Click="OnNo"/>
        </StackPanel>

    </StackPanel>
</Window>
