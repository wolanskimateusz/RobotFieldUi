<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:RobotFieldUi.ViewModels"
        x:DataType="vm:AddPathDialogViewModel"
        x:Class="RobotFieldUi.Views.Dialogs.AddPathDialog"
        Title="Nowa ścieżka"
        Width="320" Height="190"
        CanResize="False"
        WindowStartupLocation="CenterOwner">

    <StackPanel Margin="16" Spacing="10">

        <StackPanel Spacing="4">
            <TextBlock Text="Nazwa ścieżki:"/>
            <TextBox Text="{Binding PathName}" Name="PathNameBox"/>
        </StackPanel>

        <StackPanel Spacing="4">
            <TextBlock Text="Misja:"/>
            <ComboBox ItemsSource="{Binding Missions}"
                      SelectedItem="{Binding SelectedMission}"
                      HorizontalAlignment="Stretch">
                <ComboBox.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding Name}"/>
                    </DataTemplate>
                </ComboBox.ItemTemplate>
            </ComboBox>
        </StackPanel>

        <StackPanel Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Spacing="8" Margin="0,4,0,0">
            <Button Content="OK"
                    Width="80"
                    IsDefault="True"
                    Click="OnOk"/>
            <Button Content="Anuluj"
                    Width="80"
                    IsCancel="True"
                    Click="OnCancel"/>
        </StackPanel>

    </StackPanel>

</Window>
