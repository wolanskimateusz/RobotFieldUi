<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="RobotFieldUi.Views.Dialogs.ScaleDialog"
        Title="Skalowanie" Width="260" Height="115"
        CanResize="False" WindowStartupLocation="CenterOwner">
    <StackPanel Margin="16" Spacing="12">
        <Grid ColumnDefinitions="90,*">
            <TextBlock Grid.Column="0" Text="Skala (×):" VerticalAlignment="Center"/>
            <NumericUpDown x:Name="FactorInput" Grid.Column="1"
                           Value="1" Minimum="0.01" Maximum="1000"
                           Increment="0.1" FormatString="0.###"/>
        </Grid>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8">
            <Button Content="OK"     Width="80" IsDefault="True" Click="OnOk"/>
            <Button Content="Anuluj" Width="80" IsCancel="True"  Click="OnCancel"/>
        </StackPanel>
    </StackPanel>
</Window>
