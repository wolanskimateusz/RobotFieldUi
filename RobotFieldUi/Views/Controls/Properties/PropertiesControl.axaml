<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:RobotFieldUi.ViewModels"
             mc:Ignorable="d" d:DesignWidth="200" d:DesignHeight="600"
             x:Class="RobotFieldUi.Views.Controls.PropertiesControl"
             x:DataType="vm:PropertiesViewModel">

    <ScrollViewer HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="8,6" Spacing="0">

            <!-- Nagłówek -->
            <TextBlock Text="Właściwości"
                       FontSize="11"
                       Foreground="{StaticResource TextMutedBrush}"
                       Margin="0,0,0,6"/>
            <Rectangle Height="1"
                       Fill="{StaticResource SurfaceTertiaryBrush}"
                       Margin="0,0,0,10"/>

            <!-- Brak zaznaczenia -->
            <TextBlock Text="Brak zaznaczenia"
                       FontSize="11"
                       Foreground="{StaticResource TextMutedBrush}"
                       IsVisible="{Binding SelectedObject, Converter={x:Static ObjectConverters.IsNull}}"/>

            <!-- Formularz (widoczny gdy coś zaznaczone) -->
            <StackPanel IsVisible="{Binding SelectedObject, Converter={x:Static ObjectConverters.IsNotNull}}"
                        Spacing="10">

                <!-- Typ -->
                <TextBlock Text="{Binding TypeLabel}"
                           FontWeight="SemiBold"
                           FontSize="13"
                           Foreground="{StaticResource TextOnSurfaceBrush}"/>

                <!-- Sekcja: Nazwa (Project / Mission / MissionPath) -->
                <StackPanel IsVisible="{Binding HasName}" Spacing="3">
                    <TextBlock Text="Nazwa"
                               FontSize="11"
                               Foreground="{StaticResource TextMutedBrush}"/>
                    <TextBox Text="{Binding DraftName}"/>
                    <TextBlock Text="{Binding InfoLabel}"
                               FontSize="11"
                               Foreground="{StaticResource TextMutedBrush}"
                               Margin="0,2,0,0"/>
                </StackPanel>

                <!-- Sekcja: Współrzędne (PathPoint) -->
                <StackPanel IsVisible="{Binding HasCoords}" Spacing="3">
                    <TextBlock Text="Pozycja"
                               FontSize="11"
                               Foreground="{StaticResource TextMutedBrush}"/>
                    <Grid ColumnDefinitions="20,*"
                          RowDefinitions="Auto,6,Auto">
                        <TextBlock Grid.Row="0" Grid.Column="0"
                                   Text="X"
                                   FontSize="11"
                                   Foreground="{StaticResource TextMutedBrush}"
                                   VerticalAlignment="Center"/>
                        <TextBox Grid.Row="0" Grid.Column="1"
                                 Text="{Binding DraftX}"/>

                        <TextBlock Grid.Row="2" Grid.Column="0"
                                   Text="Y"
                                   FontSize="11"
                                   Foreground="{StaticResource TextMutedBrush}"
                                   VerticalAlignment="Center"/>
                        <TextBox Grid.Row="2" Grid.Column="1"
                                 Text="{Binding DraftY}"/>
                    </Grid>
                </StackPanel>

                <!-- Przycisk Zapisz -->
                <Button Content="Zapisz"
                        Command="{Binding SaveCommand}"
                        HorizontalAlignment="Stretch"
                        HorizontalContentAlignment="Center"
                        Margin="0,4,0,0"/>

            </StackPanel>

        </StackPanel>
    </ScrollViewer>

</UserControl>
