<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:RobotFieldUi.ViewModels"
             xmlns:tree="using:RobotFieldUi.Models.TreePanel"
             mc:Ignorable="d" d:DesignWidth="1200" d:DesignHeight="48"
             x:Class="RobotFieldUi.Views.Controls.RibbonControl"
             x:DataType="vm:RibbonViewModel">

    <StackPanel Orientation="Horizontal" Spacing="2" Margin="4,4">

        <!-- Grupa: Widok -->
        <Border BorderBrush="#334155" BorderThickness="1" CornerRadius="4" Padding="4,2">
            <StackPanel Orientation="Horizontal" Spacing="2">

                <ToggleButton ToolTip.Tip="Zaznacz (S)"
                              IsChecked="{Binding IsSelect}"
                              Command="{Binding SetToolCommand}"
                              CommandParameter="{x:Static vm:ActiveTool.Select}"
                              Width="36" Height="36" Padding="0">
                    <TextBlock Text="&#xE8B0;" FontFamily="Segoe MDL2 Assets" FontSize="16"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </ToggleButton>

                <ToggleButton ToolTip.Tip="Przesuń widok (H)"
                              IsChecked="{Binding IsPan}"
                              Command="{Binding SetToolCommand}"
                              CommandParameter="{x:Static vm:ActiveTool.Pan}"
                              Width="36" Height="36" Padding="0">
                    <TextBlock Text="&#xE7C4;" FontFamily="Segoe MDL2 Assets" FontSize="16"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </ToggleButton>

            </StackPanel>
        </Border>

        <Border Width="1" Background="#334155" Margin="2,6"/>

        <!-- Grupa: Edycja -->
        <Border BorderBrush="#334155" BorderThickness="1" CornerRadius="4" Padding="4,2">
            <StackPanel Orientation="Horizontal" Spacing="2">

                <ToggleButton ToolTip.Tip="Dodaj punkt (P)"
                              IsChecked="{Binding IsAddPoint}"
                              Command="{Binding SetToolCommand}"
                              CommandParameter="{x:Static vm:ActiveTool.AddPoint}"
                              Width="36" Height="36" Padding="0">
                    <TextBlock Text="&#xECC8;" FontFamily="Segoe MDL2 Assets" FontSize="16"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </ToggleButton>

                <!-- Akcja — nie narzędzie, otwiera dialog -->
                <Button ToolTip.Tip="Dodaj ścieżkę…"
                        Command="{Binding AddPathCommand}"
                        Width="36" Height="36" Padding="0">
                    <TextBlock Text="&#xEC8F;" FontFamily="Segoe MDL2 Assets" FontSize="16"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Button>

                <ToggleButton ToolTip.Tip="Usuń (Del)"
                              IsChecked="{Binding IsDelete}"
                              Command="{Binding SetToolCommand}"
                              CommandParameter="{x:Static vm:ActiveTool.Delete}"
                              Width="36" Height="36" Padding="0">
                    <TextBlock Text="&#xE74D;" FontFamily="Segoe MDL2 Assets" FontSize="16"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </ToggleButton>

            </StackPanel>
        </Border>

        <Border Width="1" Background="#334155" Margin="2,6"/>

        <!-- Grupa: Typ segmentu -->
        <Border BorderBrush="#334155" BorderThickness="1" CornerRadius="4" Padding="4,2">
            <StackPanel Orientation="Horizontal" Spacing="2">

                <ToggleButton ToolTip.Tip="Odcinek prosty"
                              IsChecked="{Binding IsLine}"
                              Command="{Binding SetSegmentCommand}"
                              CommandParameter="{x:Static tree:SegmentType.Line}"
                              Width="36" Height="36" Padding="0">
                    <Path Data="M 3,20 L 17,6"
                          Stroke="#94a3b8" StrokeThickness="2.5" StrokeLineCap="Round"
                          Width="20" Height="20" Stretch="None"
                          HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </ToggleButton>

                <ToggleButton ToolTip.Tip="Odcinek łukowy"
                              IsChecked="{Binding IsArc}"
                              Command="{Binding SetSegmentCommand}"
                              CommandParameter="{x:Static tree:SegmentType.Arc}"
                              Width="36" Height="36" Padding="0">
                    <Path Data="M 3,18 Q 10,4 17,18"
                          Stroke="#94a3b8" StrokeThickness="2.5" StrokeLineCap="Round"
                          Width="20" Height="20" Stretch="None"
                          HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </ToggleButton>

            </StackPanel>
        </Border>

        <Border Width="1" Background="#334155" Margin="2,6"/>

        <!-- Grupa: Operacje geometryczne -->
        <Border BorderBrush="#334155" BorderThickness="1" CornerRadius="4" Padding="4,2">
            <StackPanel Orientation="Horizontal" Spacing="2">

                <!-- Okrąg -->
                <Button ToolTip.Tip="Wstaw okrąg…"
                        Command="{Binding CircleCommand}"
                        Width="36" Height="36" Padding="0">
                    <Border Width="20" Height="20"
                            HorizontalAlignment="Center" VerticalAlignment="Center">
                        <Ellipse Width="14" Height="14"
                                 Stroke="#94a3b8" StrokeThickness="2"
                                 HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                </Button>

                <!-- Przesuń (narzędzie) -->
                <ToggleButton ToolTip.Tip="Przesuń punkty (M)"
                              IsChecked="{Binding IsMove}"
                              Command="{Binding SetToolCommand}"
                              CommandParameter="{x:Static vm:ActiveTool.Move}"
                              Width="36" Height="36" Padding="0">
                    <Path Data="M 10,2 L 10,18 M 10,2 L 7,5 M 10,2 L 13,5 M 10,18 L 7,15 M 10,18 L 13,15 M 2,10 L 18,10 M 2,10 L 5,7 M 2,10 L 5,13 M 18,10 L 15,7 M 18,10 L 15,13"
                          Stroke="#94a3b8" StrokeThickness="1.5" StrokeLineCap="Round"
                          Width="20" Height="20" Stretch="None"
                          HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </ToggleButton>

                <!-- Obróć -->
                <Button ToolTip.Tip="Obróć…"
                        Command="{Binding RotateCommand}"
                        Width="36" Height="36" Padding="0">
                    <Path Data="M 5,10 A 6,6 0 1 1 12,16 M 12,16 L 9,13 M 12,16 L 15,14"
                          Stroke="#94a3b8" StrokeThickness="1.5" StrokeLineCap="Round"
                          Width="20" Height="20" Stretch="None"
                          HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Button>

                <!-- Skaluj -->
                <Button ToolTip.Tip="Skaluj…"
                        Command="{Binding ScaleTransformCommand}"
                        Width="36" Height="36" Padding="0">
                    <Path Data="M 2,2 L 7,2 M 2,2 L 2,7 M 18,2 L 13,2 M 18,2 L 18,7 M 2,18 L 7,18 M 2,18 L 2,13 M 18,18 L 13,18 M 18,18 L 18,13 M 5,5 L 15,15 M 5,15 L 15,5"
                          Stroke="#94a3b8" StrokeThickness="1.5" StrokeLineCap="Round"
                          Width="20" Height="20" Stretch="None"
                          HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Button>

                <!-- Odbij -->
                <Button ToolTip.Tip="Odbij…"
                        Command="{Binding MirrorCommand}"
                        Width="36" Height="36" Padding="0">
                    <Path Data="M 10,2 L 10,18 M 3,6 L 8,10 L 3,14 M 17,6 L 12,10 L 17,14"
                          Stroke="#94a3b8" StrokeThickness="1.5" StrokeLineCap="Round"
                          Width="20" Height="20" Stretch="None"
                          HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Button>

            </StackPanel>
        </Border>

    </StackPanel>

</UserControl>
