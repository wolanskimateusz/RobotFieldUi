<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:RobotFieldUi.ViewModels"
             xmlns:local="using:RobotFieldUi.Views.Controls"
             xmlns:canvas="clr-namespace:RobotFieldUi.Views.Controls.Canvas"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="RobotFieldUi.Views.Controls.CanvasControl"
             x:DataType="vm:CanvasViewModel">

    <Border Background="{StaticResource SurfaceCanvasBrush}"
            ClipToBounds="True">
        <Panel>

            <!-- Siatka poza transformacją — skaluje spacing by dopasować zoom -->
            <local:GridOverlay GridSpacing="40"
                               OffsetX="{Binding OffsetX}"
                               OffsetY="{Binding OffsetY}"
                               Scale="{Binding Scale}"/>

            <!-- Treść przesuwana i skalowana -->
            <Panel>
                <Panel.RenderTransform>
                    <TransformGroup>
                        <ScaleTransform ScaleX="{Binding Scale}" ScaleY="{Binding Scale}"/>
                        <TranslateTransform X="{Binding OffsetX}" Y="{Binding OffsetY}"/>
                    </TransformGroup>
                </Panel.RenderTransform>
                <canvas:PathRenderer ActivePath="{Binding ActivePath}"
                                     SelectedPoint="{Binding SelectedPoint}"
                                     SelectedPoints="{Binding SelectedPoints}"/>
            </Panel>

            <!-- Overlay na eventy myszy — bez transformacji -->
            <Canvas Name="DrawingCanvas"
                    Background="Transparent"
                    Focusable="True"
                    PointerMoved="OnPointerMoved"
                    PointerPressed="OnPointerPressed"
                    PointerReleased="OnPointerReleased"
                    PointerWheelChanged="OnPointerWheelChanged"
                    KeyDown="OnKeyDown"/>

        </Panel>
    </Border>
</UserControl>
