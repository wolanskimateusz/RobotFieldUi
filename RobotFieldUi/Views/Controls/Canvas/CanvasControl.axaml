<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:RobotFieldUi.ViewModels"
             xmlns:local="using:RobotFieldUi.Views.Controls"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="RobotFieldUi.Views.Controls.CanvasControl"
             x:DataType="vm:CanvasViewModel">
    
    <Border Background="{StaticResource SurfaceCanvasBrush}"
            ClipToBounds="True">
        <Panel>
            <local:GridOverlay GridSpacing="20"/>
            <Canvas Name="DrawingCanvas"
                    Background="Transparent"
                    PointerMoved="OnPointerMoved"/>
        </Panel>
    </Border>
</UserControl>
